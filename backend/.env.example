# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Server Port
PORT=5000

# Database Connection
MONGO_URI=mongodb+srv://your_user:your_password@your_cluster.mongodb.net/engspace?retryWrites=true&w=majority&ssl=true

# JWT Configuration
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

# VNPay Configuration
VNP_TMN_CODE=your_vnpay_code
VNP_HASH_SECRET=your_vnpay_secret
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost:5173/payment/result
